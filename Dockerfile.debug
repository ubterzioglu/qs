FROM node:22-alpine
RUN corepack enable && apk add --no-cache libc6-compat
WORKDIR /app
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY . .
ENV NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Constrain memory to mimic a small Coolify worker and surface OOM if that's the cause.
ENV NODE_OPTIONS=--max-old-space-size=256
RUN pnpm build 2>&1 | tee /tmp/b.log; echo "EXIT=${PIPESTATUS[0]}"; grep -iE "heap|memory|OOM|worker exited|prerender|digest" /tmp/b.log || true
