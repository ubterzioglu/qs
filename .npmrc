# Don't fail the install when a dependency's build script is skipped.
# Only `sharp` is allow-listed to run its script (see package.json > pnpm.onlyBuiltDependencies);
# the rest (@swc/core, @parcel/watcher, esbuild, unrs-resolver) ship prebuilt binaries and
# don't need their postinstall scripts — pnpm 10 otherwise errors under --frozen-lockfile.
strict-dep-builds=false
