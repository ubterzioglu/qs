# Supabase — provide these to enable the DB-backed CMS + forms.
# Until set, the site runs on static seed content (fully viewable, no DB needed).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by the seed script and admin server actions. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Admin panel (/admin) — single-password login.
# ADMIN_PASSWORD: the only credential to sign in (no email).
# ADMIN_SESSION_SECRET: signs the session cookie; generate with
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Public site URL (for sitemap/canonical/OG). e.g. https://qualtronsinclair.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Maintenance ("yenileniyoruz") takeover. Set to 1/true/on to show the premium
# coming-soon page to all public visitors. /admin stays reachable. Leave empty to
# run the full site. Toggle this in Vercel env + redeploy — no code change needed.
MAINTENANCE_MODE=
